@model Proyecto_Lola.Models.Categoria

@{
    ViewData["Title"] = "Details";
}

<div class="page-wrapper">

    <h1 class="page-title">Información de la categoria</h1>
    <p class="page-subtitle">Revisá los datos actuales de la categoria seleccionada.</p>

    <div class="card-elevated text-center">
        <div>
            <span class="badge-soft">
                Descripcion: @Model.Descripcion
            </span>
        </div>

        

        <div class="mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-pill-primary">
                ✏️ Editar producto
            </a>
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="link-muted">⬅ Volver a la tabla</a>
        </div>
    </div>
</div>