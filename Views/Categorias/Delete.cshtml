@model Proyecto_Lola.Models.Categoria

@{
    ViewData["Title"] = "Delete";
}





<div class="page-wrapper">

    <h1 class="page-title text-danger">¿Eliminar categoria?</h1>
    <p class="page-subtitle">Esta acción no se puede deshacer. Revisá la categoria antes de confirmar.</p>

    <div class="card-elevated text-center">

        <div>
            <span class="badge-soft" style="background-color:#fee2e2; color:#b91c1c;">
                Descripcion: @Model.Descripcion
            </span>
        </div>

        <div class="mt-4">
            <form asp-action="Delete" class="d-inline">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-pill-danger me-2">
                    🗑 Confirmar eliminación
                </button>
            </form>
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="link-muted">⬅ Cancelar y volver</a>
        </div>
    </div>
</div>