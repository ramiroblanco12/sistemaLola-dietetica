@model Proyecto_Lola.Models.Venta

@{
    ViewData["Title"] = "Delete";
}

<div class="page-wrapper">

    <h1 class="page-title text-danger">¿Eliminar Venta?</h1>
    <p class="page-subtitle">Esta acción no se puede deshacer. Revisá la venta antes de confirmar.</p>

    <div class="card-elevated text-center">

        <div class="details-grid mt-2">
            <div>
                <div class="details-label">Fecha</div>
                <div class="details-value">@Model.Fecha</div>
            </div>

            <div>
                <div class="details-label">Total</div>
                <div class="details-value">@Model.Total"</div>
            </div>

            <div class="col-12">
                <div class="details-label">Medio de Pago</div>
                <div class="details-value">@Model.MedioPago</div>
            </div>

            <div class="mt-4">
                <form asp-action="Delete" class="d-inline">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-pill-danger me-2">
                        🗑 Confirmar eliminación
                    </button>
                </form>
            </div>

            <div class="mt-3">
                <a asp-action="Index" class="link-muted">⬅ Cancelar y volver</a>
            </div>
        </div>
    </div>
</div>
