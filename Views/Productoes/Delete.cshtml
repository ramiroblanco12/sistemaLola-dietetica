@model Proyecto_Lola.Models.Producto

@{
    ViewData["Title"] = "Eliminar producto";
}

<div class="page-wrapper">

    <h1 class="page-title">Eliminar producto</h1>
    <p class="page-subtitle">Confirmá la eliminación. Esta acción no se puede deshacer.</p>

    <div class="card-elevated text-center">

        <div class="mb-3">
            <span class="badge-soft">Código: @Model.CodigoBarras</span>
        </div>

        <div class="details-grid">
            <div>
                <div class="details-label">Nombre</div>
                <div class="details-value">@Model.Nombre</div>
            </div>

            <div>
                <div class="details-label">Categoría</div>
                <div class="details-value">@Model.Categoria?.Descripcion</div>
            </div>

            <div class="col-12">
                <div class="details-label">Proveedor</div>
                <div class="details-value">@Model.Proveedor?.Nombre</div>
            </div>

            <div>
                <div class="details-label">Costo</div>
                <div class="price-highlight">$@Model.Costo.ToString("N2")</div>
            </div>

            <div>
                <div class="details-label">Precio final</div>
                <div class="price-highlight">$@Model.PrecioFinal.ToString("N2")</div>
            </div>
        </div>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-pill-danger">
                🗑️ Eliminar definitivamente
            </button>

            <a asp-action="Index" class="btn btn-pill-ghost ms-2">
                Cancelar
            </a>
        </form>

        <div class="mt-3">
            <a asp-action="Index" class="link-muted">⬅ Volver a la tabla</a>
        </div>

    </div>
</div>
