@model Proyecto_Lola.Models.Producto

@{
    ViewData["Title"] = "Detalles del producto";
}

<div class="page-wrapper">

    <h1 class="page-title">Información del producto</h1>
    <p class="page-subtitle">Revisá los datos actuales del artículo seleccionado.</p>

    <div class="card-elevated text-center">
        <div>
            <span class="badge-soft">
                Código: @Model.CodigoBarras
            </span>
        </div>

        <div class="details-grid mt-10">
            <div>
                <div class="details-label">Nombre</div>
                <div class="details-value">@Model.Nombre</div>
            </div>

            <div>
                <div class="details-label">Categoría</div>
                <div class="details-value">@Model.Categoria?.Descripcion</div>
            </div>

            <div class="col-12">
                <div class="details-label">Descripción</div>
                <div class="details-value">@Model.Descripcion</div>
            </div>
            <div class="col-12">
                <div class="details-label">Proveedor</div>
                <div class="details-value">@Model.Proveedor?.Nombre</div>
            </div>

            <div>
                <div class="details-label">Costo</div>
                <div class="price-highlight">
                    $@((Model.Costo).ToString("N2"))
                </div>
            </div>

            <div>
                <div class="details-label">Precio final</div>
                <div class="price-highlight">
                    $@((Model.PrecioFinal).ToString("N2"))
                </div>
            </div>
        </div>

        <div class="mt-4">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-pill-primary">
                ✏️ Editar producto
            </a>
        </div>

        <div class="mt-3">
            <a asp-action="Index" class="link-muted">⬅ Volver a la tabla</a>
        </div>
    </div>
</div>
